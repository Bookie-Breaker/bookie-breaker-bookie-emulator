# bookie-emulator environment variables
PORT=8005
LOG_LEVEL=info
# emulator_svc role owns the emulator schema (infra-ops init-db);
# search_path must include public for the shared enum types
DATABASE_URL=postgres://emulator_svc:localdev@localhost:5432/bookiebreaker?search_path=emulator,public
REDIS_URL=redis://localhost:6379
LINES_SERVICE_URL=http://localhost:8001
STATISTICS_SERVICE_URL=http://localhost:8002
# Paper trading bankroll (units) and unit sizing
STARTING_BANKROLL_UNITS=100
UNIT_SIZE_DOLLARS=100
# Advisory sizing config served by /bankroll (not enforced at placement)
MAX_BET_UNITS=3.0
MAX_DAILY_EXPOSURE_UNITS=10.0
KELLY_FRACTION=0.25
KELLY_ENABLED=true
# Fallback grading poller: cadence and how long after start a game is polled
GRADING_POLL_SECONDS=1800
GRADING_GRACE_SECONDS=10800
# OpenTelemetry (unset disables exporters; compose sets otel-collector:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_SERVICE_NAME=bookie-emulator
